{
  "name": "Raviraj Textiles - Phase 1 Order Automation",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "raviraj-order-paid",
        "responseMode": "onReceived",
        "responseData": "{\"received\":true}",
        "options": {}
      },
      "id": "1-webhook",
      "name": "Order Paid Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [-1400, 300],
      "webhookId": "raviraj-order-paid"
    },
    {
      "parameters": {
        "mode": "manual",
        "assignments": {
          "assignments": [
            { "name": "orderId", "type": "string", "value": "={{ $json.body.orderId }}" },
            { "name": "customerName", "type": "string", "value": "={{ $json.body.customer.name }}" },
            { "name": "customerPhone", "type": "string", "value": "={{ $json.body.customer.phone }}" },
            { "name": "customerEmail", "type": "string", "value": "={{ $json.body.customer.email }}" },
            { "name": "address", "type": "string", "value": "={{ $json.body.customer.address }}" },
            { "name": "pincode", "type": "string", "value": "={{ $json.body.customer.pincode }}" },
            { "name": "amount", "type": "number", "value": "={{ $json.body.amount }}" },
            { "name": "currency", "type": "string", "value": "={{ $json.body.currency }}" },
            { "name": "items", "type": "array", "value": "={{ $json.body.items }}" }
          ]
        },
        "options": {}
      },
      "id": "2-normalize",
      "name": "Normalize Order Data",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [-1160, 300]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "=https://api.postalpincode.in/pincode/{{ $json.pincode }}",
        "options": {}
      },
      "id": "3-pincode-lookup",
      "name": "Lookup City/State from Pincode",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [-920, 300],
      "continueOnFail": true
    },
    {
      "parameters": {
        "mode": "manual",
        "assignments": {
          "assignments": [
            { "name": "city", "type": "string", "value": "={{ $json[0]?.PostOffice?.[0]?.District ?? 'NA' }}" },
            { "name": "state", "type": "string", "value": "={{ $json[0]?.PostOffice?.[0]?.State ?? 'Tamil Nadu' }}" }
          ]
        },
        "options": {}
      },
      "id": "4-attach-city-state",
      "name": "Attach City/State",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [-680, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://graph.facebook.com/v20.0/{{ $env.WHATSAPP_PHONE_NUMBER_ID }}/messages",
        "authentication": "none",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Authorization", "value": "=Bearer {{ $env.WHATSAPP_ACCESS_TOKEN }}" },
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ {\n  \"messaging_product\": \"whatsapp\",\n  \"to\": $node['Normalize Order Data'].json.customerPhone,\n  \"type\": \"text\",\n  \"text\": {\n    \"body\": \"Hi \" + $node['Normalize Order Data'].json.customerName + \", your Raviraj Textiles order \" + $node['Normalize Order Data'].json.orderId + \" is confirmed! We'll send your tracking number as soon as it ships. Thank you for shopping with us.\"\n  }\n} }}",
        "options": {}
      },
      "id": "5-whatsapp-confirm",
