            { "name": "x-internal-secret", "value": "={{ $env.INTERNAL_API_SECRET }}" },
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ {\n  \"orderId\": $node['Normalize Order Data'].json.orderId,\n  \"shiprocketOrderId\": $json.shiprocketOrderId,\n  \"shiprocketShipmentId\": $json.shiprocketShipmentId,\n  \"awbCode\": $json.awbCode,\n  \"courierName\": $json.courierName,\n  \"trackingUrl\": $json.trackingUrl\n} }}",
        "options": {}
      },
      "id": "12-backend-fulfillment-update",
      "name": "Backend: Update Order + Tracking",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1000, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.BACKEND_URL }}/internal/reduce-stock",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "x-internal-secret", "value": "={{ $env.INTERNAL_API_SECRET }}" },
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ { \"items\": $node['Normalize Order Data'].json.items.map(i => ({ \"id\": i.id, \"qty\": i.quantity })) } }}",
        "options": {}
      },
      "id": "13-backend-reduce-stock",
      "name": "Backend: Reduce Stock",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1240, 300],
      "continueOnFail": true
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://graph.facebook.com/v20.0/{{ $env.WHATSAPP_PHONE_NUMBER_ID }}/messages",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Authorization", "value": "=Bearer {{ $env.WHATSAPP_ACCESS_TOKEN }}" },
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ {\n  \"messaging_product\": \"whatsapp\",\n  \"to\": $node['Normalize Order Data'].json.customerPhone,\n  \"type\": \"text\",\n  \"text\": {\n    \"body\": \"Good news \" + $node['Normalize Order Data'].json.customerName + \"! Your order \" + $node['Normalize Order Data'].json.orderId + \" has shipped via \" + $json.courierName + \". Tracking number: \" + $json.awbCode + \". Track it here: \" + $json.trackingUrl\n  }\n} }}",
        "options": {}
      },
      "id": "14-whatsapp-tracking",
      "name": "WhatsApp: Tracking Update",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1480, 220],
      "continueOnFail": true
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.resend.com/emails",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Authorization", "value": "=Bearer {{ $env.RESEND_API_KEY }}" },
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ {\n  \"from\": \"Raviraj Textiles <orders@ravirajtextile.com>\",\n  \"to\": [ $node['Normalize Order Data'].json.customerEmail ],\n  \"subject\": \"Your order \" + $node['Normalize Order Data'].json.orderId + \" has shipped!\",\n  \"html\": \"<p>Hi \" + $node['Normalize Order Data'].json.customerName + \",</p><p>Your order has shipped via \" + $json.courierName + \".</p><p>Tracking number: <b>\" + $json.awbCode + \"</b><br/>Track here: <a href='\" + $json.trackingUrl + \"'>\" + $json.trackingUrl + \"</a></p><p>Thank you for shopping with Raviraj Textiles!</p>\"\n} }}",
        "options": {}
      },
      "id": "15-email-tracking",
      "name": "Email: Tracking Update",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1480, 380],
      "continueOnFail": true
    }
  ],
  "connections": {
    "Order Paid Webhook": { "main": [ [ { "node": "Normalize Order Data", "type": "main", "index": 0 } ] ] },
    "Normalize Order Data": { "main": [ [ { "node": "Lookup City/State from Pincode", "type": "main", "index": 0 } ] ] },
