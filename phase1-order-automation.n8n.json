      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [-440, 180],
      "continueOnFail": true
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://invoice-generator.com",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Authorization", "value": "=Bearer {{ $env.INVOICE_GENERATOR_API_KEY }}" },
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ {\n  \"from\": \"Raviraj Textiles\\n12/12 Pappapatty Katu Valu, Kadayampatty Road\\nElampillai, Salem, Tamil Nadu 637502\\nPh: +91 93456 73735\",\n  \"to\": $node['Normalize Order Data'].json.customerName + \"\\n\" + $node['Normalize Order Data'].json.address + \"\\nPIN: \" + $node['Normalize Order Data'].json.pincode,\n  \"number\": $node['Normalize Order Data'].json.orderId,\n  \"currency\": \"inr\",\n  \"items\": $node['Normalize Order Data'].json.items.map(i => ({ \"name\": i.name, \"quantity\": i.quantity, \"unit_cost\": i.price })),\n  \"notes\": \"Thank you for shopping with Raviraj Textiles!\"\n} }}",
        "options": { "response": { "response": { "responseFormat": "file" } } }
      },
      "id": "6-generate-invoice",
      "name": "Generate Invoice PDF",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [-440, 340],
      "continueOnFail": true
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.resend.com/emails",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Authorization", "value": "=Bearer {{ $env.RESEND_API_KEY }}" },
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ {\n  \"from\": \"Raviraj Textiles <orders@ravirajtextile.com>\",\n  \"to\": [ $node['Normalize Order Data'].json.customerEmail ],\n  \"subject\": \"Order Confirmed - \" + $node['Normalize Order Data'].json.orderId,\n  \"html\": \"<p>Hi \" + $node['Normalize Order Data'].json.customerName + \",</p><p>Your order <b>\" + $node['Normalize Order Data'].json.orderId + \"</b> is confirmed. Your invoice is attached. We'll email/WhatsApp your tracking number as soon as it ships.</p><p>Thank you for shopping with Raviraj Textiles!</p>\",\n  \"attachments\": [ { \"filename\": \"invoice-\" + $node['Normalize Order Data'].json.orderId + \".pdf\", \"content\": $binary.data.data } ]\n} }}",
        "options": {}
      },
      "id": "7-email-confirm",
      "name": "Email: Order Confirmation",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [-200, 340],
      "continueOnFail": true
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://apiv2.shiprocket.in/v1/external/auth/login",
        "sendHeaders": true,
        "headerParameters": { "parameters": [ { "name": "Content-Type", "value": "application/json" } ] },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ { \"email\": $env.SHIPROCKET_EMAIL, \"password\": $env.SHIPROCKET_PASSWORD } }}",
        "options": {}
      },
      "id": "8-shiprocket-auth",
      "name": "Shiprocket: Auth",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [40, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://apiv2.shiprocket.in/v1/external/orders/create/adhoc",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Authorization", "value": "=Bearer {{ $json.token }}" },
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ {\n  \"order_id\": $node['Normalize Order Data'].json.orderId,\n  \"order_date\": $now.toFormat('yyyy-LL-dd HH:mm'),\n  \"pickup_location\": $env.SHIPROCKET_PICKUP_LOCATION,\n  \"billing_customer_name\": $node['Normalize Order Data'].json.customerName,\n  \"billing_last_name\": \"\",\n  \"billing_address\": $node['Normalize Order Data'].json.address,\n  \"billing_city\": $node['Attach City/State'].json.city,\n  \"billing_pincode\": $node['Normalize Order Data'].json.pincode,\n  \"billing_state\": $node['Attach City/State'].json.state,\n  \"billing_country\": \"India\",\n  \"billing_email\": $node['Normalize Order Data'].json.customerEmail,\n  \"billing_phone\": $node['Normalize Order Data'].json.customerPhone,\n  \"shipping_is_billing\": true,\n  \"order_items\": $node['Normalize Order Data'].json.items.map(i => ({ \"name\": i.name, \"sku\": i.id, \"units\": i.quantity, \"selling_price\": i.price })),\n  \"payment_method\": \"Prepaid\",\n  \"sub_total\": $node['Normalize Order Data'].json.amount,\n  \"length\": Number($env.SHIPROCKET_PKG_LENGTH_CM || 30),\n  \"breadth\": Number($env.SHIPROCKET_PKG_BREADTH_CM || 25),\n  \"height\": Number($env.SHIPROCKET_PKG_HEIGHT_CM || 5),\n  \"weight\": ($node['Normalize Order Data'].json.items.reduce((s,i)=>s+i.quantity,0) * Number($env.SHIPROCKET_WEIGHT_PER_ITEM_KG || 0.5))\n} }}",
        "options": {}
      },
      "id": "9-shiprocket-create-order",
      "name": "Shiprocket: Create Order",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [280, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://apiv2.shiprocket.in/v1/external/courier/assign/awb",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Authorization", "value": "=Bearer {{ $node['Shiprocket: Auth'].json.token }}" },
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ { \"shipment_id\": $json.payload.shipment_id } }}",
        "options": {}
      },
      "id": "10-shiprocket-assign-awb",
      "name": "Shiprocket: Assign AWB",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [520, 300]
    },
    {
      "parameters": {
        "mode": "manual",
        "assignments": {
          "assignments": [
            { "name": "awbCode", "type": "string", "value": "={{ $json.response.data.awb_code }}" },
            { "name": "courierName", "type": "string", "value": "={{ $json.response.data.courier_name }}" },
            { "name": "trackingUrl", "type": "string", "value": "=https://shiprocket.co/tracking/{{ $json.response.data.awb_code }}" },
            { "name": "shiprocketOrderId", "type": "string", "value": "={{ $node['Shiprocket: Create Order'].json.order_id }}" },
            { "name": "shiprocketShipmentId", "type": "string", "value": "={{ $node['Shiprocket: Create Order'].json.payload.shipment_id }}" }
          ]
        },
        "options": {}
      },
      "id": "11-extract-tracking",
      "name": "Extract Tracking Info",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [760, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.BACKEND_URL }}/internal/fulfillment-update",
