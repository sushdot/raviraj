# Copy this file to ".env" and fill in your real values.
# Never commit the real ".env" file to git.

# Razorpay — https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_key_secret_here
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_here

# Supabase — https://app.supabase.com -> Project Settings -> API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Automation hub that receives paid-order notifications
# (Zapier / Make / n8n / your own endpoint)
FULFILLMENT_WEBHOOK_URL=https://your-automation-hub.com/hooks/orders

# Server port (optional — defaults to 3000)
PORT=3000

# Phase 1 — shared secret for internal automation endpoints
# (/internal/reduce-stock, /internal/fulfillment-update).
# Generate any long random string, e.g.: openssl rand -hex 32
# Put the SAME value in your n8n HTTP Request node headers.
INTERNAL_API_SECRET=your_long_random_secret_here
